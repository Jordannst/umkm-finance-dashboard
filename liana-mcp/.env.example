# =====================================================================
# umkm-finance-mcp - Contoh environment variables
# =====================================================================
# File ini cuma referensi. MCP server tidak baca .env file langsung -
# OpenClaw harus pass env saat register lewat `--env KEY=VALUE`.
#
# Lihat README.md di folder ini untuk panduan setup OpenClaw.
# =====================================================================

# Base URL dashboard yang sudah deploy.
# Local dev:    http://localhost:3000
# Production:   https://your-app.vercel.app
DASHBOARD_URL="http://localhost:3000"

# Shared secret untuk endpoint /api/liana/*. WAJIB sama persis dengan
# yang di-set di Vercel env. Generate string acak >= 32 karakter.
LIANA_SHARED_SECRET="ganti-dengan-string-acak-panjang"

# UUID business. Ambil dari halaman Settings -> Profil bisnis di dashboard
# (atau dari supabase/seed.sql kalau pakai demo data).
BUSINESS_ID="00000000-0000-0000-0000-000000000001"
