# =====================================================================
# Dashboard Keuangan UMKM - Contoh environment variables
# =====================================================================
# Copy file ini menjadi `.env.local` lalu isi dengan nilai sebenarnya.
# Jangan pernah commit `.env.local` atau `.env`. Service role key dan
# shared secret HARUS server-only - tidak boleh diawali NEXT_PUBLIC_.
# =====================================================================

# --- Supabase (wajib) ------------------------------------------------
# Ambil dari https://app.supabase.com/project/_/settings/api

# Boleh diakses browser, hanya untuk anon access (RLS berlaku).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only. Memberikan akses penuh ke database (bypass RLS).
# Jangan pernah expose ke client / browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Integrasi Liana / chat agent (wajib untuk Sprint 6) -------------
# Shared secret yang dipakai Liana saat memanggil endpoint /api/liana/*.
# Generate string acak panjang (>= 32 karakter), rahasiakan.
LIANA_SHARED_SECRET="ganti-dengan-string-acak-panjang"

# --- Default business untuk MVP single-tenant ------------------------
# UUID business demo dari tabel `businesses` (lihat supabase/seed.sql).
# Digunakan saat user belum login atau saat Liana tidak mengirim
# business_id eksplisit.
NEXT_PUBLIC_DEMO_BUSINESS_ID="11111111-1111-4111-8111-111111111111"

# --- Liana / OpenClaw integrasi -------------------------------------
#
# Tombol "Tanya Liana" punya 3 mode (auto-pilih berdasarkan env):
#   1. send    : POST ke /api/liana/ask -> forward ke OpenClaw /hooks/agent
#                Liana langsung respond di Telegram. Paling smooth.
#                Aktif kalau NEXT_PUBLIC_LIANA_SEND_ENABLED=1 + hooks env diset.
#   2. telegram: Deep link buka https://t.me/<bot>?text=<prompt>.
#                Aktif kalau NEXT_PUBLIC_OPENCLAW_BOT_USERNAME diset.
#   3. copy    : Fallback - copy prompt ke clipboard.

# Username bot Telegram OpenClaw tanpa "@".
# Dipakai untuk: (a) deep link mode (b) tombol "Buka @bot" di settings.
NEXT_PUBLIC_OPENCLAW_BOT_USERNAME="OpenClaw_BOT"

# Aktifkan mode "send" (forward via /api/liana/ask). Set ke "1" / "true"
# kalau OPENCLAW_HOOKS_URL + OPENCLAW_HOOK_TOKEN sudah siap. Kalau kosong,
# tombol fallback ke deep link Telegram (mode 2 di atas).
NEXT_PUBLIC_LIANA_SEND_ENABLED=""

# Base URL public OpenClaw hooks (HTTPS). Server-only, jangan prefix
# NEXT_PUBLIC_. Diakses dari Vercel server route, bukan dari browser.
# Contoh: https://openclaw.example.com  (TIDAK termasuk /hooks/agent path).
# Liana saat ini default loopback 127.0.0.1:18789 - butuh tunnel/reverse proxy.
OPENCLAW_HOOKS_URL=""

# Path hooks endpoint. Default "/hooks/agent" sesuai spec OpenClaw.
# Override hanya kalau Gateway-mu punya custom path.
OPENCLAW_HOOKS_PATH="/hooks/agent"

# Bearer token untuk auth ke OpenClaw /hooks/agent.
# Server-only. Generate di OpenClaw config, simpan rahasia.
OPENCLAW_HOOK_TOKEN=""

# OPSIONAL: aktifkan field `sessionKey` di body request ke OpenClaw.
# Default OpenClaw blokir field ini dari external hooks dengan error 400:
#   "sessionKey is disabled for externally supplied hooks".
# Untuk enable di OpenClaw, set di config gateway:
#   hooks.allowRequestSessionKey: true
# lalu restart openclaw-gateway. SESUDAH itu, set var ini ke "1"/"true" supaya
# wrapper ikut kirim sessionKey -> Liana ingat context user antar prompt.
# Default kosong = jangan kirim sessionKey (compatible dengan default OpenClaw).
OPENCLAW_HOOKS_ALLOW_SESSION_KEY=""

# --- App ------------------------------------------------------------
# Base URL untuk app, dipakai untuk:
#   - Redirect Supabase Auth callback
#   - Link absolut di OG metadata
#   - Build callback URL ke /api/liana/run-callback yang dipassing ke
#     OpenClaw (Liana POST balik ke URL ini saat reply terkirim Telegram).
# WAJIB diisi di production. Contoh: "https://umkm-finance-dashboard.vercel.app"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
